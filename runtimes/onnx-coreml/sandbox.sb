;;; NeuralMesh macOS sandbox profile — ONNX Runtime + CoreML EP
;;; Applied via: sandbox-exec -f <this-file> python3 <script>

(version 1)
(deny default)

;;; ── Job working directory ─────────────────────────────────────────────────
(allow file-read*
  (subpath "JOB_DIR"))
(allow file-write*
  (subpath "JOB_DIR"))

;;; ── System libraries ──────────────────────────────────────────────────────
(allow file-read*
  (subpath "/usr/lib")
  (subpath "/usr/local/lib")
  (subpath "/System/Library")
  (subpath "/private/var/db/dyld")
  (subpath "/Library/Apple")
  (literal "/etc/localtime")
  (literal "/private/etc/localtime"))

;;; ── Python interpreter + packages ────────────────────────────────────────
(allow file-read*
  (subpath "/usr/bin")
  (subpath "/opt/homebrew/bin")
  (subpath "/opt/homebrew/lib")
  (subpath "/opt/homebrew/Cellar")
  (subpath "/opt/homebrew/opt")
  (subpath "/Library/Python")
  (subpath "/usr/local/bin")
  (subpath "/usr/local/lib"))

;;; ── CoreML + Metal + ANE (Apple Neural Engine) frameworks ────────────────
(allow file-read*
  (subpath "/System/Library/Frameworks/CoreML.framework")
  (subpath "/System/Library/Frameworks/Metal.framework")
  (subpath "/System/Library/Frameworks/MetalPerformanceShaders.framework")
  (subpath "/System/Library/Frameworks/Accelerate.framework")
  (subpath "/System/Library/Frameworks/Foundation.framework")
  (subpath "/System/Library/Frameworks/Vision.framework")
  (subpath "/System/Library/PrivateFrameworks"))

;;; ── ONNX Runtime CoreML cache ─────────────────────────────────────────────
(allow file-read* file-write*
  (subpath (string-append (param "HOME") "/Library/Caches/com.microsoft.onnxruntime"))
  (subpath "/private/var/folders"))

;;; ── CoreML compiled model cache ───────────────────────────────────────────
(allow file-read* file-write*
  (subpath (string-append (param "HOME") "/Library/Caches/CoreML")))

;;; ── HuggingFace model cache (read-only) ──────────────────────────────────
(allow file-read*
  (subpath (string-append (param "HOME") "/.cache/huggingface")))

;;; ── Temp files ────────────────────────────────────────────────────────────
(allow file-read* file-write*
  (subpath "/private/tmp"))

;;; ── Process / Mach ────────────────────────────────────────────────────────
(allow process-exec
  (subpath "/usr/bin")
  (subpath "/opt/homebrew/bin")
  (subpath "/usr/local/bin"))
(allow process-fork)

;;; ── Mach IPC (required for CoreML / ANE access) ──────────────────────────
(allow mach-lookup)
(allow mach-register)

;;; ── IOKit ─────────────────────────────────────────────────────────────────
(allow iokit-open)
(allow iokit-get-properties)

;;; ── Network: localhost only ───────────────────────────────────────────────
(allow network-outbound
  (local tcp)
  (local udp))
(deny network-outbound)

;;; ── Signals ───────────────────────────────────────────────────────────────
(allow signal
  (target self))

;;; ── sysctl reads ─────────────────────────────────────────────────────────
(allow sysctl-read)
