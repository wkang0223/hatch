# ══════════════════════════════════════════════════════════════════════════════
# NeuralMesh — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# DO NOT commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://neuralmesh:CHANGE_ME@localhost:5432/neuralmesh

# ── NATS JetStream ────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3-compatible artifact store (MinIO in dev, AWS S3 / Cloudflare R2 in prod) ─
ARTIFACT_STORE_URL=http://localhost:9000
ARTIFACT_STORE_BUCKET=neuralmesh-artifacts
ARTIFACT_STORE_KEY=CHANGE_ME
ARTIFACT_STORE_SECRET=CHANGE_ME

# ── Coordinator service ───────────────────────────────────────────────────────
GRPC_ADDR=0.0.0.0:9090
REST_ADDR=0.0.0.0:8080
# Publicly reachable HTTPS base URL of this coordinator (no trailing slash).
# Used to build artifact download URLs returned to provider agents.
# Example (Railway): https://hatch-coordinator.up.railway.app
NM_PUBLIC_URL=https://neuralmesh-coordinator-production-666f.up.railway.app

# ── Ledger service ────────────────────────────────────────────────────────────
LEDGER_REST_ADDR=0.0.0.0:8082
PLATFORM_FEE_PCT=8

# ── Dashboard (Next.js) ───────────────────────────────────────────────────────
# Public URL of the coordinator REST API (used by the browser)
NEXT_PUBLIC_COORDINATOR_URL=https://api.neuralmesh.io
# Public URL of the ledger REST API
NEXT_PUBLIC_LEDGER_URL=https://ledger.neuralmesh.io
# Your public dashboard domain (for CORS, redirects)
NEXTAUTH_URL=https://app.neuralmesh.io

# ── Stripe (fiat → NMC deposits, pays out to your bank account) ──────────────
# Get these from https://dashboard.stripe.com/apikeys
# Stripe auto-pays out to your connected bank account T+2 business days.
# For Malaysia: connect a Malaysian bank via Stripe Dashboard → Settings → Bank accounts
# Supports FPX (online banking) + credit/debit cards for Malaysian payers.
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Internal secret used by Next.js webhook → coordinator ledger credit call
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=CHANGE_ME_RANDOM_SECRET

# ── Arbitrum / EVM (optional — for on-chain NMC bridge) ─────────────────────
# Deployer private key (keep in KMS / secrets manager in production)
PRIVATE_KEY=0xCHANGE_ME
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_URL_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc

# Deployed contract addresses (set after running forge script)
NMC_TOKEN_ADDRESS=
PROVIDER_NFT_ADDRESS=
ESCROW_ADDRESS=
QUANTUM_VERIFIER_ADDRESS=

# Oracle multisig (3 separate keys for 2-of-3 threshold)
ORACLE_1=
ORACLE_2=
ORACLE_3=
FEE_COLLECTOR=

# ── Solana (optional — for on-chain NMC bridge) ───────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Deployer keypair JSON path (keep in secrets manager in production)
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
